#!/usr/bin/env groovy
/**
 * FLUID Universal Pipeline - Atomic & Declarative
 * 
 * This pipeline is a generic template for ANY FLUID Data Product.
 * It delegates all logic to the FLUID CLI, ensuring the contract is the source of truth.
 * 
 * Philosophy: 
 * - The Pipeline is Dumb (It just calls 'fluid' commands)
 * - The Contract is Smart (It defines dbt, infrastructure, and loading)
 * - The CLI is the Engine (It executes the contract atomically)
 * 
 * Key Features Demonstrated:
 * ✅ Declarative contract validation
 * ✅ Open standards interoperability (ODPS, ODCS)
 * ✅ Quality gates and testing
 * ✅ Terraform-style planning
 * ✅ Multi-modal deployment (immediate + scheduled)
 * ✅ Airflow DAG generation from contracts
 * ✅ Post-deployment verification
 * 
 * Write Once, Execute Anywhere:
 * - Same contract → CI/CD immediate execution
 * - Same contract → Airflow scheduled execution
 * - Same contract → ODPS/ODCS open standards
 */

pipeline {
    agent {
        docker {
            // Use the image with the FLUID CLI pre-installed
            image 'localhost:5000/fluid-forge-cli:0.7.1'
            // Mount docker socket to allow 'fluid local run' (DinD) if needed in future
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    
    environment {
        // High-level environment context only
        ENV = "${BRANCH_NAME == 'main' ? 'prod' : BRANCH_NAME == 'develop' ? 'staging' : 'dev'}"
        
        // Map Jenkins Credential to the standard Google Auth Variable
        // FLUID CLI will pick this up automatically for authentication
        GOOGLE_APPLICATION_CREDENTIALS = credentials('gcp-service-account')
    }
    
    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        ansiColor('xterm')
        disableConcurrentBuilds()
    }
    
    stages {
        // --------------------------------------------------------
        // Stage 1: Validation (Syntax & Schema)
        // --------------------------------------------------------
        stage('🛡️ Validate') {
            steps {
                script {
                    echo "🔍 Validating contract syntax..."
                    
                    // Create directories for artifacts
                    sh "mkdir -p standards"
                    
                    // Validate FLUID contract
                    sh "fluid validate contract.fluid.yaml"
                }
            }
        }

        // --------------------------------------------------------
        // Stage 2: Open Standards Export & Validation
        // --------------------------------------------------------
        stage('📜 Open Standards') {
            steps {
                script {
                    echo "📜 Demonstrating FLUID's support for open standards..."
                    
                    // Export to ODPS (Open Data Product Specification v4.1)
                    // The Linux Foundation standard for data products
                    sh """
                        fluid odps export contract.fluid.yaml \\
                            --out standards/contract.odps.json \\
                            --pretty \\
                            --validate
                    """
                    
                    // Export to ODCS (Open Data Contract Standard v3.1)
                    // Bitol.io standard for data contracts
                    sh """
                        fluid odcs export contract.fluid.yaml \\
                            --output standards/contract.odcs.yaml \\
                            --format yaml
                    """
                    
                    // Validate the exported ODPS file
                    echo "✅ Validating ODPS export..."
                    sh "fluid odps validate standards/contract.odps.json"
                    
                    // Validate the exported ODCS file
                    echo "✅ Validating ODCS export..."
                    sh "fluid odcs validate standards/contract.odcs.yaml"
                    
                    // Archive the standards-compliant exports
                    archiveArtifacts artifacts: 'standards/*.{json,yaml}', allowEmptyArchive: false
                    
                    echo "✨ Successfully demonstrated interoperability with open standards!"
                }
            }
        }
        
        // --------------------------------------------------------
        // Stage 3: Contract Tests (Logic & Quality)
        // --------------------------------------------------------
        stage('🧪 Contract Tests') {
            steps {
                script {
                    echo "🧪 Running contract tests..."
                    // This runs dbt tests + FLUID quality gates defined in the YAML
                    sh "fluid contract-tests contract.fluid.yaml"
                }
            }
        }
        
        // --------------------------------------------------------
        // Stage 4: Plan (Dry Run / Impact Analysis)
        // --------------------------------------------------------
        stage('📐 Plan') {
            steps {
                script {
                    echo "📋 Generating execution plan for ${ENV}..."
                    // Generates a JSON plan showing exactly what will change (Terraform-style)
                    sh "fluid plan contract.fluid.yaml --env ${ENV} --out plan.json --verbose"
                    
                    // Archive plan for review
                    archiveArtifacts artifacts: 'plan.json', allowEmptyArchive: true
                }
            }
        }
        
        // --------------------------------------------------------
        // Stage 5: Multi-Modal Deployment
        // Demonstrates: Write Once, Execute Anywhere
        // --------------------------------------------------------
        stage('🔄 Deploy') {
            when {
                anyOf { branch 'main'; branch 'develop' }
            }
            steps {
                script {
                    // Manual Approval for Production
                    if (ENV == 'prod') {
                        timeout(time: 60, unit: 'MINUTES') {
                            input message: "Deploy to PRODUCTION?", ok: "Ship It", submitter: 'admin'
                        }
                    }

                    // Create DAGs directory for artifacts
                    sh "mkdir -p airflow-dags"

                    parallel(
                        // Mode 1: Immediate Execution (CI/CD)
                        "Immediate Execution": {
                            echo "🚀 Executing contract immediately via fluid apply..."
                            sh "fluid apply plan.json --env ${ENV} --debug"
                        },
                        
                        // Mode 2: Airflow DAG Generation (Production Scheduling)
                        "Airflow DAG": {
                            echo "🌬️ Generating Airflow DAG for scheduled execution..."
                            sh """
                                fluid generate-airflow contract.fluid.yaml \\
                                    --output airflow-dags/bitcoin-tracker.py \\
                                    --dag-id bitcoin_price_tracker_${ENV} \\
                                    --schedule '@hourly' \\
                                    --tags 'bitcoin,crypto,fluid,${ENV}'
                            """
                            
                            // Validate generated DAG is valid Python
                            echo "✅ Validating generated DAG syntax..."
                            sh "python3 -m py_compile airflow-dags/bitcoin-tracker.py"
                            
                            // Archive DAG for deployment to Airflow
                            archiveArtifacts artifacts: 'airflow-dags/*.py', fingerprint: true
                            
                            echo "✨ DAG ready for Airflow deployment!"
                        }
                    )
                }
            }
        }
        
        // --------------------------------------------------------
        // Stage 6: Verification (Post-Deploy Smoke Tests)
        // --------------------------------------------------------
        stage('✅ Verify') {
            when {
                anyOf { branch 'main'; branch 'develop' }
            }
            steps {
                script {
                    echo "🔎 Verifying deployment..."
                    // Checks if the deployed state matches the contract schema
                    sh "fluid verify contract.fluid.yaml --env ${ENV}"
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        failure {
            echo "❌ Pipeline Failed. Check logs."
        }
        success {
            echo "✅ Pipeline Succeeded."
        }
    }
}