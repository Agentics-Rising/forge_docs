#!/usr/bin/env groovy
/**
 * FLUID Data Product CI/CD Pipeline
 * 
 * This pipeline demonstrates end-to-end CI/CD for declarative data products
 * using FLUID 0.7.1 framework with comprehensive logging and validation.
 * 
 * Pipeline Stages:
 * 1. Setup - Environment validation and dependency installation
 * 2. Validate Contract - FLUID contract schema validation
 * 3. Static Analysis - Data quality rules and policy checks
 * 4. Plan Deployment - Generate execution plan without applying
 * 5. Run Tests - dbt tests and data validation
 * 6. Deploy to Staging - Apply contract to staging environment
 * 7. Integration Tests - Verify data quality in staging
 * 8. Deploy to Production - Apply contract to production
 * 9. Post-Deployment - Verify and monitor
 */

pipeline {
    agent any
    
    options {
        // Keep last 30 builds
        buildDiscarder(logRotator(numToKeepStr: '30'))
        // Timeout after 30 minutes
        timeout(time: 30, unit: 'MINUTES')
        // Add timestamps to console output
        timestamps()
        // Disable concurrent builds
        disableConcurrentBuilds()
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production'],
            description: 'Deployment environment'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip test execution (not recommended for production)'
        )
        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Plan only, do not apply changes'
        )
        string(
            name: 'GCP_PROJECT_ID',
            defaultValue: 'dust-labs-485011',
            description: 'GCP Project ID for deployment'
        )
    }
    
    environment {
        // GCP credentials - update 'gcp-service-account' to match your Jenkins credential ID
        GOOGLE_APPLICATION_CREDENTIALS = credentials('gcp-service-account')
        
        // FLUID CLI configuration
        FLUID_PROVIDER = 'gcp'
        FLUID_PROJECT = "${params.GCP_PROJECT_ID}"
        GCP_PROJECT_ID = "${params.GCP_PROJECT_ID}"
        
        // Python environment
        PYTHONUNBUFFERED = '1'
        
        // dbt configuration
        DBT_PROFILES_DIR = "${WORKSPACE}/dbt"
        DBT_PROJECT_DIR = "${WORKSPACE}/dbt"
        
        // Artifact paths
        CONTRACT_FILE = 'contract.fluid.yaml'
        PLAN_OUTPUT = 'runtime/plan.json'
        VALIDATION_REPORT = 'runtime/validation-report.json'
        TEST_RESULTS = 'runtime/test-results.json'
    }
    
    stages {
        stage('🚀 Setup Environment') {
            steps {
                script {
                    echo """
                    ═══════════════════════════════════════════════════════════
                    FLUID Data Product CI/CD Pipeline
                    ═══════════════════════════════════════════════════════════
                    Build Number: ${env.BUILD_NUMBER}
                    Environment: ${params.ENVIRONMENT}
                    GCP Project: ${params.GCP_PROJECT_ID}
                    Dry Run: ${params.DRY_RUN}
                    Skip Tests: ${params.SKIP_TESTS}
                    Workspace: ${env.WORKSPACE}
                    ═══════════════════════════════════════════════════════════
                    """
                    
                    // Change to bitcoin-tracker directory
                    dir('.') {
                        echo "📂 Working directory: ${pwd()}"
                        
                        // Verify contract file exists
                        sh '''
                            echo "🔍 Verifying contract file..."
                            if [ ! -f "${CONTRACT_FILE}" ]; then
                                echo "❌ ERROR: Contract file not found: ${CONTRACT_FILE}"
                                exit 1
                            fi
                            echo "✅ Contract file found"
                            echo ""
                            echo "📄 Contract Summary:"
                            head -20 ${CONTRACT_FILE}
                        '''
                        
                        // Install Python dependencies in virtual environment
                        echo "📦 Installing Python dependencies..."
                        sh '''
                            # Create virtual environment if it doesn't exist
                            if [ ! -d "venv" ]; then
                                echo "Creating virtual environment..."
                                python3 -m venv venv
                            fi
                            
                            # Activate virtual environment and install dependencies
                            . venv/bin/activate
                            pip install --upgrade pip setuptools wheel
                            
                            # Install FLUID Build from local PyPI server
                            echo ""
                            echo "🔍 Installing FLUID Build from PyPI server..."
                            pip install --index-url http://myuser:pypipass123@192.168.178.121:8080/simple/ \
                                        --trusted-host 192.168.178.121 \
                                        fluid_build==0.7.1 && \
                                echo "✅ FLUID Build 0.7.1 installed from PyPI server" || \
                                echo "⚠️  FLUID Build installation failed - pipeline will use YAML validation only"
                            
                            # Install other dependencies
                            pip install dbt-core dbt-bigquery google-cloud-bigquery requests pyyaml
                            echo "✅ Dependencies installed in virtual environment"
                            
                            # Verify installations
                            echo ""
                            echo "📦 Installed packages:"
                            python3 -c "import fluid_build; print(f'  ✅ FLUID Build: {fluid_build.__version__}')" 2>/dev/null || echo "  ⚠️  FLUID Build: not available"
                            python3 -c "import dbt.version; print(f'  ✅ dbt-core: {dbt.version.get_installed_version()}')"
                            python3 -c "import google.cloud.bigquery; print('  ✅ google-cloud-bigquery: installed')"
                        '''
                        
                        // Verify GCP credentials
                        echo "🔑 Verifying GCP credentials..."
                        sh '''
                            if [ -z "${GOOGLE_APPLICATION_CREDENTIALS}" ]; then
                                echo "⚠️  GOOGLE_APPLICATION_CREDENTIALS not set"
                                echo "   Attempting to use Application Default Credentials..."
                                
                                # Check if gcloud is authenticated
                                if gcloud auth application-default print-access-token > /dev/null 2>&1; then
                                    echo "✅ Using Application Default Credentials"
                                else
                                    echo "❌ No GCP credentials available"
                                    echo "   Run: gcloud auth application-default login"
                                    echo "   Or set GOOGLE_APPLICATION_CREDENTIALS environment variable"
                                    echo ""
                                    echo "⚠️  Pipeline will continue but may fail on GCP operations"
                                fi
                            else
                                echo "✅ Using service account: ${GOOGLE_APPLICATION_CREDENTIALS}"
                            fi
                            
                            # Set GCP project
                            gcloud config set project ${GCP_PROJECT_ID} 2>/dev/null || echo "⚠️  gcloud not configured"
                        '''
                        
                        // Create runtime directory
                        sh '''
                            mkdir -p runtime
                            echo "✅ Runtime directory ready"
                        '''
                    }
                }
            }
        }
        
        stage('✅ Validate Contract') {
            steps {
                dir('.') {
                    script {
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 2: FLUID Contract Validation
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo "🔍 Validating FLUID contract..."
                            echo ""
                            
                            # Check if FLUID Build is available
                            if python3 -c "import fluid_build" 2>/dev/null; then
                                # Run FLUID validation with detailed output
                                python3 -m fluid_build.cli validate ${CONTRACT_FILE} 2>&1 | tee ${VALIDATION_REPORT}
                                VALIDATION_EXIT_CODE=$?
                                
                                echo ""
                                if [ ${VALIDATION_EXIT_CODE} -eq 0 ]; then
                                    echo "✅ Contract validation PASSED"
                                    echo "   Contract is compliant with FLUID 0.7.1 schema"
                                else
                                    echo "❌ Contract validation FAILED"
                                    echo "   Review errors above and fix contract file"
                                    exit 1
                                fi
                            else
                                echo "⚠️  FLUID Build not available - skipping validation"
                                echo "   Using basic YAML syntax check instead"
                                python3 -c "import yaml; yaml.safe_load(open('${CONTRACT_FILE}'))" && echo "✅ Contract YAML is valid" || { echo "❌ Contract YAML is invalid"; exit 1; }
                                echo "{\"status\": \"skipped\", \"reason\": \"FLUID Build not available\"}" > ${VALIDATION_REPORT}
                            fi
                            
                            # Display contract metadata
                            echo ""
                            echo "📊 Contract Metadata:"
                            python3 << 'EOF'
import yaml
with open('contract.fluid.yaml') as f:
    contract = yaml.safe_load(f)
    print(f"  ID: {contract.get('id', 'N/A')}")
    print(f"  Version: {contract.get('fluidVersion', 'N/A')}")
    print(f"  Exposes: {len(contract.get('exposes', []))} datasets")
    print(f"  Builds: {len(contract.get('builds', []))} transformations")
EOF
                        '''
                    }
                }
            }
            post {
                always {
                    // Archive validation report
                    archiveArtifacts artifacts: 'runtime/validation-report.json', 
                                     allowEmptyArchive: true
                }
            }
        }
        
        stage('📋 Static Analysis') {
            steps {
                dir('.') {
                    script {
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 3: Static Analysis & Policy Checks
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        sh '''
                            echo "🔍 Analyzing contract for best practices..."
                            echo ""
                            
                            # Check for required governance metadata
                            echo "1. Checking governance metadata..."
                            python3 << EOF
import yaml
import sys

with open("${CONTRACT_FILE}") as f:
    contract = yaml.safe_load(f)

issues = []

# Check product-level metadata
if not contract.get('labels'):
    issues.append("⚠️  Missing product-level labels for FinOps tracking")
if not contract.get('metadata', {}).get('owner'):
    issues.append("⚠️  Missing owner metadata")

# Check expose-level policies
for expose in contract.get('exposes', []):
    expose_id = expose.get('exposeId')
    if not expose.get('policy'):
        issues.append(f"⚠️  {expose_id}: Missing policy definition")
    if not expose.get('labels'):
        issues.append(f"⚠️  {expose_id}: Missing labels for cost tracking")
    
    # Check field-level metadata
    schema = expose.get('contract', {}).get('schema', [])
    for field in schema:
        if not field.get('description'):
            issues.append(f"⚠️  {expose_id}.{field['name']}: Missing description")

if issues:
    print("\\n".join(issues))
    print(f"\\nFound {len(issues)} metadata issues")
    if len(issues) > 5:
        print("❌ Too many metadata issues, failing build")
        sys.exit(1)
    else:
        print("⚠️  Issues found but not blocking")
else:
    print("✅ All governance checks passed")
EOF
                            
                            # Check for sensitive data markers
                            echo ""
                            echo "2. Checking for PII/sensitive data..."
                            grep -i "sensitivity.*internal" ${CONTRACT_FILE} && {
                                echo "⚠️  Found fields marked as 'internal' sensitivity"
                                echo "   Ensure proper access controls are in place"
                            } || echo "✅ No sensitive data markers found"
                            
                            # Validate dbt models exist
                            echo ""
                            echo "3. Validating dbt models..."
                            for model in daily_price_summary price_trends; do
                                if [ -f "dbt/models/${model}.sql" ]; then
                                    echo "   ✅ Found: dbt/models/${model}.sql"
                                else
                                    echo "   ❌ Missing: dbt/models/${model}.sql"
                                    exit 1
                                fi
                            done
                            
                            echo ""
                            echo "✅ Static analysis complete"
                        '''
                    }
                }
            }
        }
        
        stage('📐 Plan Deployment') {
            steps {
                dir('.') {
                    script {
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 4: Generate Deployment Plan
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo "📐 Generating deployment plan..."
                            echo ""
                            
                            # Generate plan without applying
                            set +e  # Don't exit on error, we want to capture exit code
                            python3 -m fluid_build.cli plan ${CONTRACT_FILE} \
                                --provider ${FLUID_PROVIDER} \
                                --project ${FLUID_PROJECT} \
                                --debug 2>&1 | tee runtime/plan-output.log
                            PLAN_EXIT_CODE=$?
                            set -e  # Re-enable exit on error
                            
                            if [ $PLAN_EXIT_CODE -ne 0 ]; then
                                echo "❌ Plan generation failed with exit code $PLAN_EXIT_CODE"
                                echo "   Check runtime/plan-output.log for details"
                                exit 1
                            fi
                            
                            echo ""
                            echo "📊 Deployment Plan Summary:"
                            if [ -f "${PLAN_OUTPUT}" ]; then
                                python3 << EOF
import json
with open("${PLAN_OUTPUT}") as f:
    plan = json.load(f)
    actions = plan.get('actions', [])
    print(f"  Total Actions: {len(actions)}")
    
    action_types = {}
    for action in actions:
        action_type = action.get('type', 'unknown')
        action_types[action_type] = action_types.get(action_type, 0) + 1
    
    for action_type, count in sorted(action_types.items()):
        print(f"    • {action_type}: {count}")
EOF
                            else
                                echo "  ⚠️  Plan file not found, using console output"
                            fi
                            
                            echo ""
                            echo "✅ Plan generated successfully"
                        '''
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'runtime/plan*.{json,log}',
                                     allowEmptyArchive: true
                }
            }
        }
        
        stage('🧪 Run Tests') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                dir('.') {
                    script {
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 5: Data Quality Tests
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo "🧪 Running dbt tests..."
                            echo ""
                            
                            # Run dbt tests with detailed output
                            cd dbt
                            set +e  # Don't exit on error
                            set -o pipefail  # Get exit code from dbt, not tee
                            dbt test --project-dir . --profiles-dir . 2>&1 | tee ../runtime/dbt-test-output.log
                            DBT_EXIT_CODE=$?
                            set +o pipefail
                            set -e  # Re-enable exit on error
                            cd ..
                            
                            if [ $DBT_EXIT_CODE -eq 0 ]; then
                                echo ""
                                echo "✅ All dbt tests passed"
                            else
                                echo ""
                                echo "⚠️  Some dbt tests failed, review output above"
                                if [ "$ENVIRONMENT" = "production" ]; then
                                    echo "❌ Test failures not allowed for production deployment"
                                    exit 1
                                else
                                    echo "⚠️  Continuing with staging deployment"
                                fi
                            fi
                            
                            # Run custom data quality checks
                            echo ""
                            echo "🔍 Running data quality checks..."
                            
                            # Create Python script to avoid backtick issues
                            cat > runtime/quality_checks.py << 'PYEOF'
import sys
import os
from google.cloud import bigquery

project_id = os.environ['GCP_PROJECT_ID']
client = bigquery.Client(project=project_id)

checks_passed = 0
checks_failed = 0

# Check 1: Verify table exists and has data
try:
    table = client.get_table(f"{project_id}.crypto_data.bitcoin_prices")
    row_count = table.num_rows
    print(f"✅ bitcoin_prices exists with {row_count} rows")
    if row_count == 0:
        print("⚠️  Table is empty")
        checks_failed += 1
    else:
        checks_passed += 1
except Exception as e:
    print(f"❌ Failed to access bitcoin_prices: {e}")
    checks_failed += 1

# Check 2: Verify no NULL prices
query = f"""
SELECT COUNT(*) as null_count
FROM `{project_id}.crypto_data.bitcoin_prices`
WHERE price_usd IS NULL
"""
try:
    result = list(client.query(query))[0]
    if result.null_count == 0:
        print(f"✅ No NULL prices found")
        checks_passed += 1
    else:
        print(f"❌ Found {result.null_count} NULL prices")
        checks_failed += 1
except Exception as e:
    print(f"⚠️  Could not verify NULL prices: {e}")

# Check 3: Verify recent data (within 24 hours)
query = f"""
SELECT 
    MAX(price_timestamp) as latest_timestamp,
    TIMESTAMP_DIFF(CURRENT_TIMESTAMP(), MAX(price_timestamp), HOUR) as hours_old
FROM `{project_id}.crypto_data.bitcoin_prices`
"""
try:
    result = list(client.query(query))[0]
    if result.hours_old <= 24:
        print(f"✅ Data is fresh ({result.hours_old} hours old)")
        checks_passed += 1
    else:
        print(f"⚠️  Data is stale ({result.hours_old} hours old)")
        checks_failed += 1
except Exception as e:
    print(f"⚠️  Could not verify data freshness: {e}")

print()
print(f"📊 Test Summary: {checks_passed} passed, {checks_failed} failed")
environment = os.environ.get('ENVIRONMENT', 'staging')
if checks_failed > 0 and environment == "production":
    sys.exit(1)
PYEOF
                            
                            python3 runtime/quality_checks.py
                        '''
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'runtime/dbt-test-output.log',
                                     allowEmptyArchive: true
                }
            }
        }
        
        stage('🚀 Deploy') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                dir('.') {
                    script {
                        def stageName = params.ENVIRONMENT == 'production' ? '🔴 Deploy to Production' : '🟡 Deploy to Staging'
                        
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 6: ${stageName}
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        // For production, require manual approval
                        if (params.ENVIRONMENT == 'production') {
                            input message: 'Deploy to Production?', 
                                  ok: 'Deploy',
                                  submitter: 'admin,release-manager'
                        }
                        
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo "🚀 Deploying to $ENVIRONMENT..."
                            echo ""
                            
                            # Authenticate gcloud with service account for bq commands
                            if [ -n "${GOOGLE_APPLICATION_CREDENTIALS}" ]; then
                                echo "🔐 Activating service account for gcloud/bq..."
                                gcloud auth activate-service-account --key-file="${GOOGLE_APPLICATION_CREDENTIALS}"
                                gcloud config set project ${GCP_PROJECT_ID}
                            fi
                            
                            # Note: fluid apply currently has issues with label propagation
                            # Using manual BigQuery updates as workaround
                            
                            echo "📊 Current BigQuery state:"
                            bq ls --project_id=${GCP_PROJECT_ID} crypto_data
                            
                            echo ""
                            echo "🔄 Running dbt models..."
                            cd dbt
                            set +e
                            set -o pipefail  # Get exit code from dbt, not tee
                            dbt run --project-dir . --profiles-dir . 2>&1 | tee ../runtime/dbt-run-output.log
                            DBT_EXIT_CODE=$?
                            set +o pipefail
                            set -e
                            cd ..
                            
                            if [ $DBT_EXIT_CODE -ne 0 ]; then
                                echo "❌ dbt run failed"
                                exit 1
                            fi
                            
                            echo ""
                            echo "🏷️  Applying labels to BigQuery resources..."
                            
                            # Apply labels to bitcoin_prices table
                            bq update \
                                --set_label environment:${ENVIRONMENT} \
                                --set_label cost-center:engineering \
                                --set_label cost-allocation:crypto-team \
                                --set_label sla-tier:silver \
                                ${GCP_PROJECT_ID}:crypto_data.bitcoin_prices || echo "⚠️  Failed to update table labels"
                            
                            # Apply labels to views
                            bq update \
                                --set_label materialized:view \
                                --set_label update-frequency:real-time \
                                --set_label aggregation-level:daily \
                                --set_label cost-allocation:crypto-team \
                                ${GCP_PROJECT_ID}:crypto_data.daily_price_summary || echo "⚠️  Failed to update view labels"
                            
                            bq update \
                                --set_label materialized:view \
                                --set_label analysis-type:technical \
                                --set_label update-frequency:real-time \
                                --set_label cost-allocation:crypto-team \
                                ${GCP_PROJECT_ID}:crypto_data.price_trends || echo "⚠️  Failed to update view labels"
                            
                            echo ""
                            echo "✅ Deployment to $ENVIRONMENT complete"
                        '''
                        
                        // Load fresh data
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo ""
                            echo "📥 Loading fresh Bitcoin price data..."
                            python3 load_bitcoin_price_batch.py
                            
                            echo ""
                            echo "📊 Verifying data load..."
                            bq query --use_legacy_sql=false --project_id=${GCP_PROJECT_ID} \
                                'SELECT COUNT(*) as total_rows, 
                                        MAX(price_timestamp) as latest_update,
                                        ROUND(AVG(price_usd), 2) as avg_price
                                 FROM `crypto_data.bitcoin_prices`'
                        '''
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'runtime/dbt-run-output.log',
                                     allowEmptyArchive: true
                }
            }
        }
        
        stage('✅ Verify Deployment') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                dir('.') {
                    script {
                        echo """
                        ═══════════════════════════════════════════════════════════
                        Stage 7: Post-Deployment Verification
                        ═══════════════════════════════════════════════════════════
                        """
                        
                        sh '''
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            # Activate virtual environment
                            . venv/bin/activate
                            
                            echo "🔍 Verifying deployment..."
                            echo ""
                            
                            # Run FLUID verify
                            python3 -m fluid_build.cli verify ${CONTRACT_FILE} 2>&1 | tee runtime/verify-output.log
                            
                            echo ""
                            echo "📊 Checking BigQuery resources..."
                            
                            # Verify all tables/views exist
                            for resource in bitcoin_prices daily_price_summary price_trends; do
                                echo ""
                                echo "Checking ${resource}..."
                                bq show --format=prettyjson ${GCP_PROJECT_ID}:crypto_data.${resource} | jq '{
                                    type: .type,
                                    rows: .numRows,
                                    labels: .labels
                                }'
                            done
                            
                            echo ""
                            echo "📈 Sample data from views..."
                            
                            # Query daily summary
                            echo ""
                            echo "daily_price_summary (latest day):"
                            bq query --use_legacy_sql=false --project_id=${GCP_PROJECT_ID} --max_rows=1 \
                                'SELECT date, data_points, open_price_usd, close_price_usd, daily_volatility 
                                 FROM `crypto_data.daily_price_summary` 
                                 ORDER BY date DESC LIMIT 1'
                            
                            # Query price trends
                            echo ""
                            echo "price_trends (latest 3 records):"
                            bq query --use_legacy_sql=false --project_id=${GCP_PROJECT_ID} --max_rows=3 \
                                'SELECT price_timestamp, price_usd, ma_7day_usd, trend_vs_7day_ma 
                                 FROM `crypto_data.price_trends` 
                                 ORDER BY price_timestamp DESC LIMIT 3'
                            
                            echo ""
                            echo "✅ Verification complete"
                        '''
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'runtime/verify-output.log',
                                     allowEmptyArchive: true
                }
            }
        }
    }
    
    post {
        success {
            script {
                echo """
                ═══════════════════════════════════════════════════════════
                ✅ Pipeline Completed Successfully
                ═══════════════════════════════════════════════════════════
                Environment: ${params.ENVIRONMENT}
                Build: ${env.BUILD_NUMBER}
                Duration: ${currentBuild.durationString}
                
                Next Steps:
                  • View data in BigQuery Console:
                    https://console.cloud.google.com/bigquery?project=${params.GCP_PROJECT_ID}
                  
                  • Monitor data freshness and quality
                  • Set up alerting for data SLAs
                  • Review cost allocation by labels
                ═══════════════════════════════════════════════════════════
                """
            }
        }
        
        failure {
            script {
                echo """
                ═══════════════════════════════════════════════════════════
                ❌ Pipeline Failed
                ═══════════════════════════════════════════════════════════
                Build: ${env.BUILD_NUMBER}
                Stage: ${env.STAGE_NAME}
                
                Troubleshooting:
                  • Review console output above for error details
                  • Check archived artifacts for detailed logs
                  • Verify GCP credentials and permissions
                  • Validate contract syntax and schema
                ═══════════════════════════════════════════════════════════
                """
            }
        }
        
        always {
            script {
                // Clean up temporary files but keep logs
                dir('.') {
                    sh '''
                        echo "🧹 Cleaning up temporary files..."
                        rm -f *.pyc
                        find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
                        echo "✅ Cleanup complete"
                    '''
                }
            }
        }
    }
}
