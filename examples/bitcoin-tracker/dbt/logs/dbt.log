  create or replace view `dust-labs-485011`.`crypto_data_crypto_data`.`daily_price_summary`
  OPTIONS()
  as 

-- Daily Bitcoin price summary
-- Calculates daily OHLC (Open, High, Low, Close) and volatility metrics
SELECT 
  DATE(price_timestamp) as date,
  
  -- Price statistics
  MIN(price_usd) as min_price_usd,
  MAX(price_usd) as max_price_usd,
  AVG(price_usd) as avg_price_usd,
  FIRST_VALUE(price_usd) OVER (PARTITION BY DATE(price_timestamp) ORDER BY price_timestamp ASC) as open_price_usd,
  FIRST_VALUE(price_usd) OVER (PARTITION BY DATE(price_timestamp) ORDER BY price_timestamp DESC) as close_price_usd,
  
  -- Volatility
  STDDEV(price_usd) as daily_volatility,
  MAX(price_usd) - MIN(price_usd) as price_range,
  
  -- Volume and market cap
  AVG(market_cap_usd) as avg_market_cap_usd,
  SUM(volume_24h_usd) / COUNT(*) as avg_volume_24h_usd,  -- Average to avoid double counting
  
  -- Additional metrics
  AVG(price_eur) as avg_price_eur,
  AVG(price_gbp) as avg_price_gbp,
  COUNT(*) as data_points,
  MIN(price_timestamp) as first_update,
  MAX(price_timestamp) as last_update

FROM `dust-labs-485011`.`crypto_data`.`bitcoin_prices`

GROUP BY DATE(price_timestamp)
ORDER BY date DESC;


